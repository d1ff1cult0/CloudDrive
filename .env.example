# ============================================================================
#  Vault configuration
#  For a normal Docker install you only need to set STORAGE_PATH (and APP_URL
#  if you expose it publicly). Everything else has working defaults.
# ============================================================================

# --- Docker install (docker compose) -------------------------------------
# Where your files are stored on the host. This is the ONLY setting most
# people need to change. Defaults to ./storage next to docker-compose.yml.
STORAGE_PATH=/mnt/ext_storage

# Public URL of the app. Keep the default for local use; set it to your
# Cloudflare Tunnel / reverse-proxy hostname when exposing Vault publicly.
APP_URL=http://localhost:3033

# Optional: a 32+ char secret for auth. Leave blank to have one generated and
# persisted automatically on first start. Set it explicitly to pin it.
#   generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# ============================================================================
# --- Local development (pnpm dev, without Docker) ------------------------
# Only needed if you run the app directly with pnpm rather than Docker.
# Point DATABASE_URL at a Postgres instance (e.g. `docker compose up postgres`).
# ============================================================================
# DATABASE_URL="postgresql://vault:vault@localhost:5432/vault?schema=public"
# STORAGE_PATH is optional in dev; it falls back to ./data/drive1
